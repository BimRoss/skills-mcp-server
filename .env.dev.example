# Copy to `.env.dev` (gitignored). Loaded by `../agents-mcp-server/docker-compose.yml` (skills-mcp-server service).
SKILLS_MCP_SERVER_PORT=8081
SKILLS_MCP_SERVER_DIR=./skills
# Copy examples/*/ into SKILLS_MCP_SERVER_DIR on startup when skill not already present
SKILLS_SEED_EXAMPLES=true
SKILLS_EXAMPLES_DIR=examples
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ENABLE_WEB_RESEARCH=true

# Google Docs — create_google_doc (optional; tool errors until set)
# Prefer JOANNE_GOOGLE_* so the same .env can include portal GOOGLE_OAUTH_* without mismatched refresh tokens.
JOANNE_GOOGLE_CLIENT_ID=
JOANNE_GOOGLE_CLIENT_SECRET=
JOANNE_GOOGLE_REFRESH_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
